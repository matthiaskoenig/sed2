          "title": "Qualifier"
        }
      },
      "required": [
        "value",
        "qualifier"
      ],
      "title": "Annotation",
      "type": "object"
    },
    "BQB": {
      "description": "MIRIAM biological qualifier.",
      "enum": [
        "BQB_IS",
        "BQB_HAS_PART",
        "BQB_IS_PART_OF",
        "BQB_IS_VERSION_OF",
        "BQB_HAS_VERSION",
        "BQB_IS_HOMOLOG_TO",
        "BQB_IS_DESCRIBED_BY",
        "BQB_IS_ENCODED_BY",
        "BQB_ENCODES",
        "BQB_OCCURS_IN",
        "BQB_HAS_PROPERTY",
        "BQB_IS_PROPERTY_OF",
        "BQB_HAS_TAXON",
        "BQB_UNKNOWN"
      ],
      "title": "BQB",
      "type": "string"
    },
    "BQM": {
      "description": "MIRIAM model qualifier.",
      "enum": [
        "BQM_IS",
        "BQM_IS_DESCRIBED_BY",
        "BQM_IS_DERIVED_FROM",
        "BQM_IS_INSTANCE_OF",
        "BQM_HAS_INSTANCE",
        "BQM_UNKNOWN"
      ],
      "title": "BQM",
      "type": "string"
    },
    "Data": {
      "description": "A value passed between tasks \u2014 either a concrete literal or a reference to another task's output.\n\nUse a bare Python value (str, float, list, \u2026) for literals, or a string starting\nwith '#' to reference another task's output port (e.g. '#modelImport1.model').\nOutput port declarations leave `value` as None \u2014 the value is produced at runtime.",
      "properties": {
        "value": {
          "default": null,
          "title": "Value"
        },
        "accessors": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Accessors"
        },
        "datatypes": {
