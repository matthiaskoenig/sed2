      "type": "object"
    },
    "outputs": {
      "additionalProperties": {
        "$ref": "#/$defs/PortSchema"
      },
      "default": {},
      "title": "Outputs",
      "type": "object"
    }
  },
  "required": [
    "type"
  ],
  "title": "TaskDefinition",
  "type": "object"
