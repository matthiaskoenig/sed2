  "description": "Abstract description of a task type stored in the task registry.\n\nDefines the interface (port names and schemas) without specifying how the\ntask is implemented. The concrete Python implementation is registered\nseparately by matching on `type`. Serializes to/from JSON for the registry.",
  "properties": {
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Name"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
